#!/usr/bin/env bash

set -e

# check if gum exists
if ! command -v gum &>/dev/null; then
  echo "'gum' not found"
  exit
fi

EDITOR=$(gum choose "hx" "code" "nvim")

TYPE=$(gum choose "neovim configs" "configs" "linux dots" "windows dots")

if [ "$TYPE" = "neovim configs" ]; then
  $EDITOR "$HOME/.config/nvim"
elif [ "$TYPE" = "configs" ]; then
  $EDITOR "$HOME/.config"
elif [ "$TYPE" = "linux dots" ]; then
  $EDITOR "$HOME/dotfiles"
elif [ "$TYPE" = "windows dots" ]; then
  $EDITOR "$HOME/dotfiles-windows"
fi
